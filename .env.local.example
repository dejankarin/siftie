# =============================================================================
# Siftie env vars — copy this file to .env.local and fill in the values.
# .env.local is gitignored, so secrets never leave your machine.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (auth)
# -----------------------------------------------------------------------------
# From: https://dashboard.clerk.com → your Siftie app → API Keys
# - Publishable key starts with "pk_test_" (dev) or "pk_live_" (prod)
# - Secret key starts with "sk_test_" or "sk_live_"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Webhook signing secret. Set this AFTER first deploy in Session 1, when we
# create the webhook endpoint at https://siftie.app/api/clerk/webhook in the
# Clerk dashboard. Leave blank for now — we'll fill this in together.
CLERK_WEBHOOK_SECRET=

# Where our sign-in / sign-up pages live in the app. Without these, Clerk's
# middleware redirects unauthenticated users to the hosted Account Portal at
# accounts.siftie.app, which leaves our app's visual frame.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Where Clerk sends users after successful sign-in / sign-up. Defaults to /
# but we want them to land directly in the workspace.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Where Clerk sends users after sign-out (UserButton menu → Sign out).
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# -----------------------------------------------------------------------------
# Supabase (database + realtime)
# -----------------------------------------------------------------------------
# From: https://supabase.com/dashboard → your project → Settings → API
# - Project URL looks like: https://xxxxxxxxxxxxxxxx.supabase.co
# - anon (public) key is a long JWT, safe to expose to the browser
# - service_role key is a long JWT, SERVER-ONLY (bypasses RLS)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# These two are duplicates of the URL + anon key above, but with the
# NEXT_PUBLIC_ prefix so the browser can read them. Use the SAME values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# AES-256-GCM master key for encrypting per-user provider keys (BYOK)
# -----------------------------------------------------------------------------
# Generate ONCE with: openssl rand -base64 32
# Save a copy in 1Password or similar — losing this means every user has to
# re-paste their Gemini/OpenRouter/Tavily/Peec keys.
KEY_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# PostHog Cloud EU (analytics + LLM observability)
# -----------------------------------------------------------------------------
# From: https://eu.posthog.com → your project → Settings → Project API Key
# Project API key is safe to expose to the browser. Host is fixed for EU.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Optional — only needed in Session 9 to provision evals/dashboards via API.
# If skipped, we'll set them up by clicking around the dashboard instead.
# From: https://eu.posthog.com → Settings → Personal API Keys
POSTHOG_PERSONAL_API_KEY=

# -----------------------------------------------------------------------------
# App URL (used in metadata, auth callbacks, webhook URLs)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://siftie.app
